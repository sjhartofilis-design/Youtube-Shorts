# Copy this file to .env.local and fill in your Supabase project's values
# (Project Settings > Data API in the Supabase dashboard). These are safe to
# expose in client-side code — access is enforced by Row Level Security, not
# by keeping the anon key secret.
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key
